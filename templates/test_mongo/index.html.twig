{% extends 'base.html.twig' %}

{% block title %}Test MongoDB{% endblock %}

{% block body %}
<main class="container main" style="padding-top: 2rem;">

    <h1>Collection <code>test</code> — MongoDB</h1>

    <form method="post" action="{{ path('app_test_mongo_new') }}" class="card p-3 mb-4" style="max-width: 500px;">
        <h5 class="mb-3">Ajouter un document</h5>
        <div class="mb-2">
            <input type="text" name="nom" class="form-control" placeholder="Nom" required>
        </div>
        <div class="mb-2">
            <input type="text" name="message" class="form-control" placeholder="Message" required>
        </div>
        <button type="submit" class="btn btn-primary">Insérer</button>
    </form>

    {% if documents is empty %}
        <p class="text-muted">Aucun document dans la collection.</p>
    {% else %}
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                {% for doc in documents %}
                    <tr>
                        <td><code>{{ doc.id }}</code></td>
                        <td>{{ doc.nom }}</td>
                        <td>{{ doc.message }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

</main>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Administration - Utilisateurs{% endblock %}

{% block body %}

<div class="container mt-4">
    <h1 class="mb-4">Gestion des utilisateurs</h1>

    <div class="mb-3">
        <a class="btn btn-success" href="{{ path('app_admin_user_new') }}">
            + Créer un utilisateur
        </a>
    </div>


    <table class="table table-striped table-hover aligne-middle">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Téléphone</th>
                <th>Adresse</th>
                <th>Actions</th>
            </tr>
        </thead>



        <tbody>
        {% for user in users %}
            <tr>


                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>

                <td>
                    {% for role in user.roles %}
                        <span class="badge 
                            {% if role == 'ROLE_ADMIN' %}
                                bg-danger
                            {% elseif role == 'ROLE_EMPLOYEE' %}
                                bg-warning text-dark
                            {% else %}
                                bg-secondary
                            {% endif %}
                        ">
                            {{ role|replace({'ROLE_': ''}) }}
                        </span>
                    {% endfor %}
                </td>

                <td>{{ user.lastname }}</td>
                <td>{{ user.firstname }}</td>
                <td>{{ user.phone }}</td>
                <td>{{ user.postalAdress }}</td>

                <td>
                    <a class="btn btn-sm btn-primary"
                    href="{{ path('app_admin_user_show', {'id': user.id}) }}">voir</a>
                    <a class="btn btn-sm btn-primary"
                    href="{{ path('app_admin_user_edit', {'id': user.id}) }}">modifier</a>
                

                {{ include('admin/user/_delete_form.html.twig', { user: user }) }}

                </td>

            </tr>
        {% else %}
            <tr>
                <td colspan="8" class="text-center text-muted">Aucun utilisateur trouvé</td>
            </tr>
        {% endfor %}
        
        </tbody>
    </table>
</div>
    
{% endblock %}

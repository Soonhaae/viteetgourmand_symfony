{% extends 'base.html.twig' %}

{% block title %}Accueil - Vite&Gourmand{% endblock %}

{% block body %}

<main class="page-bg main">

    <div class="container page-inner">

        <div class="separation darker"></div>

        <!-- BLOC 1 -->
        <section class="section-block section-tight">
            <h2 class="section-title-center">Une entreprise aux petits oignons</h2>

            <div class="section-block-top">

                <div class="section-text-card">
                    <p>
                        <span class="marque">Vite&Gourmand</span> régale Bordeaux et ses alentours avec une cuisine généreuse,
                        authentique et pleine de saveurs.
                    </p>
                </div>

                <div class="photo-wrapper">
                    <div class="photo-back"></div>
                    <div class="photo-front">
                        <img src="{{ asset('img/ui/duo.png') }}" alt="Équipe Vite&Gourmand">
                    </div>
                </div>

            </div>

            <div class="section-block-bottom">

                <div class="photo-wrapper">
                    <div class="photo-back"></div>
                    <div class="photo-front">
                        <img src="{{ asset('img/ui/table_mariage.jpg') }}" alt="Table mariage">
                    </div>
                </div>

                <div class="section-text-card">
                    <p>
                        Traiteur de proximité, <span class="marque">Vite&Gourmand</span> accompagne tous vos événements.
                    </p>
                </div>

            </div>
        </section>

        <div class="separation dark"></div>

        <!-- BLOC 2 -->
        <section class="section-block section-alt">
            <h2 class="section-title-center">Nos équipes à votre service</h2>

            <div class="section-block-top">

                <div class="photo-wrapper">
                    <div class="photo-back"></div>
                    <div class="photo-front">
                        <img src="{{ asset('img/ui/equipe_cuisine.png') }}" alt="Équipe cuisine">
                    </div>
                </div>

                <div class="section-text-card">
                    <p>
                        Chez <span class="marque">Vite&Gourmand</span>, le professionnalisme repose sur trois équipes.
                    </p>
                </div>

            </div>

            <div class="section-block-bottom">

                <div class="section-text-card">
                    <p><strong>L’équipe logistique</strong> organise tout.</p>
                    <p><strong>L’équipe livraison</strong> assure la ponctualité.</p>
                </div>

                <div class="photo-wrapper">
                    <div class="photo-back"></div>
                    <div class="photo-front">
                        <img src="{{ asset('img/ui/les_deux_equipes.png') }}" alt="Équipes">
                    </div>
                </div>

            </div>
        </section>

        <div class="separation shadow"></div>

        <!-- BLOC 3 -->
        <section class="section-block section-tight">
            <h2 class="section-title-center">Retours d’expérience</h2>

            <div class="reviews-grid">
                {% for review in publishedReviews %}
                    <article class="review-card">
                        <h3 class="review-title">{{ review.commande.menu.theme }}</h3>
                        <p class="review-stars" aria-label="{{ review.rating }}/5">
                            {% for star in 1..5 %}
                                {% if star <= review.rating %}&#9733;{% else %}&#9734;{% endif %}
                            {% endfor %}
                        </p>
                        <p class="review-text">“{{ review.publicExcerpt }}”</p>
                    </article>
                {% else %}
                    <p class="reviews-empty">Les premiers avis publiés seront affichés ici.</p>
                {% endfor %}
            </div>
        </section>

    </div>

</main>

{% endblock %}

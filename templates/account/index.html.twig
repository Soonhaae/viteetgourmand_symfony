{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
    <main class="container main account-page">
        <div class="account-card">
            <h1>Mon compte</h1>
            <p>Bonjour {{ app.user.firstname }}.</p>

            <div class="account-actions">
                <a class="btn btn-primary" href="{{ path('app_commande_index') }}">mes commandes</a>

                {% if is_granted('ROLE_EMPLOYEE') %}
                    <a class="btn btn-outline-secondary" href="{{ path('app_gestion_commande_index') }}">gestion des commandes</a>
                    <a class="btn btn-outline-secondary" href="{{ path('app_menu_index') }}">gestion des menus</a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-outline-secondary" href="{{ path('app_admin_user_index') }}">administration utilisateurs</a>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}

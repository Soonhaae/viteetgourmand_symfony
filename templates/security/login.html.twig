{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <main class="container main login-page">
        <form class="login-card" method="post">
            <h1>Se connecter</h1>

            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3">
                    Vous êtes connecté, {{ app.user.firstname }} {{ app.user.lastname|first|upper }}., <a href="{{ logout_path() }}">se déconnecter</a>
                </div>
            {% endif %}

            <div class="mb-3">
                <label for="username">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
            </div>

            <div class="mb-4">
                <label for="password">Mot de passe</label>
                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                <button class="password-toggle" type="button" data-password-toggle="password">
                    afficher le mot de passe
                </button>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div class="login-actions">
                <button class="btn btn-primary" type="submit">
                    se connecter
                </button>
            </div>
        </form>
    </main>
{% endblock %}

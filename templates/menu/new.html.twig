{% extends 'base.html.twig' %}

{% block title %}Créer un menu{% endblock %}

{% block body %}
    <main class="container main menu-form-page">
        <div class="menu-form-card">
            <h1>Créer un menu</h1>

            {{ include('menu/_form.html.twig', {'form_id': 'menu-form-new'}) }}

            <div class="menu-form-actions">
                <button class="btn btn-primary" type="submit" form="menu-form-new">Sauvegarder</button>
                <a href="{{ path('app_menu_index') }}" class="btn btn-outline-secondary">retour à la liste</a>
            </div>
        </div>
    </main>
{% endblock %}

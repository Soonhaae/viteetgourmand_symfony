{% extends 'base.html.twig' %}

{% block title %}Menu{% endblock %}

{% block body %}
    <h1>Menu</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ menu.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ menu.title }}</td>
            </tr>
            <tr>
                <th>Theme</th>
                <td>{{ menu.theme }}</td>
            </tr>
            <tr>
                <th>Regime</th>
                <td>{{ menu.regime }}</td>
            </tr>
            <tr>
                <th>Content</th>
                <td>{{ menu.content }}</td>
            </tr>
            <tr>
                <th>MinPersons</th>
                <td>{{ menu.minPersons }}</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ menu.price }}</td>
            </tr>
            <tr>
                <th>Conditions</th>
                <td>{{ menu.conditions }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ menu.status ? menu.status.label : '?' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_menu_index') }}">back to list</a>

    <a href="{{ path('app_menu_edit', {'id': menu.id}) }}">edit</a>

    {{ include('menu/_delete_form.html.twig') }}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Modifier un menu{% endblock %}

{% block body %}
    <main class="container main menu-form-page">
        <div class="menu-form-card">
            <h1>Modifier un menu</h1>

            <p class="menu-entity-number">menu n° <span class="menu-number-badge">{{ menu.id }}</span></p>

            {{ include('menu/_form.html.twig', {'form_id': 'menu-form-edit'}) }}

            <div class="menu-form-actions">
                <button class="btn btn-primary btn-soft" type="submit" form="menu-form-edit">mettre à jour</button>
                {{ include('menu/_delete_form.html.twig') }}
                <a href="{{ path('app_menu_index') }}" class="btn btn-outline-secondary">retour à la liste</a>
            </div>
        </div>
    </main>
{% endblock %}

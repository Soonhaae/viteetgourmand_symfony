{% extends 'base.html.twig' %}

{% block title %}Liste des menus{% endblock %}

{% block body %}
    <main class="container main menu-list-page">
        <div class="menu-list-card">
            <h1>Liste des menus</h1>

            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>n°</th>
                            <th>Titre</th>
                            <th>Thème</th>
                            <th>Description</th>
                            <th class="text-center">Nbr pers. min.</th>
                            <th>Prix</th>
                            <th class="text-center">Stock</th>
                            <th>Conditions</th>
                            <th>Infos suppl.</th>
                            <th>Statut</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for menu in menus %}
                        <tr>
                            <td class="text-center"><span class="menu-number-badge">{{ menu.id }}</span></td>
                            <td>{{ menu.title }}</td>
                            <td>{{ menu.theme }}</td>
                            <td>{{ menu.content }}</td>
                            <td class="text-center">{{ menu.minPersons }}</td>
                            <td>{{ menu.price }}</td>
                            <td class="text-center">{{ menu.stockAvailable }}</td>
                            <td>{{ menu.conditions }}</td>
                            <td>{{ menu.regime }}</td>
                            <td class="menu-status-cell">{{ menu.status ? menu.status.label : '?' }}</td>
                            <td>
                                <div class="menu-table-actions">
                                    <a class="btn btn-sm btn-soft menu-table-button" href="{{ path('app_menu_show', {'id': menu.id}) }}">voir</a>
                                    <a class="btn btn-sm btn-primary menu-table-button" href="{{ path('app_menu_edit', {'id': menu.id}) }}">modifier</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="12">Aucun menu trouvé</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="menu-list-actions">
                <a class="btn btn-primary" href="{{ path('app_menu_new') }}">créer un menu</a>
            </div>
        </div>
    </main>
{% endblock %}
